---
import Base from '../layouts/Base.astro';

const offerings = [
  {
    label: "Advisory",
    title: "Founder Advisory",
    description: "A standing resource for GTM decisions. For founders who want someone who's run the play before and won't just tell you what you want to hear.",
  },
  {
    label: "Fundraise",
    title: "Investor Narrative",
    description: "I help sharpen the GTM story before a raise — what the motion is, why the metrics say it's working, and how to explain it to someone writing a check.",
  },
  {
    label: "Project",
    title: "Focused Engagements",
    description: "A focused project around one problem — positioning, channel strategy, or growth infrastructure. Defined scope, real output.",
  },
];
---

<Base title="Work Together — Angela Winegar" description="GTM advisory and fractional leadership for founders and revenue teams.">
  <style>
    .cta-hero {
      padding-bottom: 5rem;
      border-bottom: 1px solid var(--color-border);
      margin-bottom: 5rem;
      max-width: 680px;
    }

    .cta-hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 800;
      line-height: 1.08;
      letter-spacing: -0.02em;
      margin-bottom: 1.25rem;
    }

    .cta-hero p {
      font-size: 1.1rem;
      color: var(--color-muted);
      line-height: 1.75;
    }

    .offerings {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--color-border);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      overflow: hidden;
      margin-bottom: 5rem;
    }

    .offering-card {
      background: var(--color-bg);
      padding: 2.25rem;
      display: flex;
      flex-direction: column;
    }

    .offering-label {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-teal);
      margin-bottom: 0.5rem;
    }

    .offering-card h3 {
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 0.85rem;
    }

    .offering-card p {
      font-size: 0.9rem;
      color: var(--color-muted);
      line-height: 1.7;
    }

    /* Contact */
    .contact {
      margin-top: 1rem;
    }

    .contact-note {
      font-size: 0.95rem;
      color: var(--color-muted);
      line-height: 1.7;
      max-width: 520px;
      margin-bottom: 1.5rem;
    }

    .contact-email-link {
      display: block;
      font-size: 0.875rem;
      color: var(--color-muted);
      margin-top: 1rem;
    }

    .contact-email-link:hover {
      color: var(--color-accent);
    }

    @media (max-width: 760px) {
      .offerings { grid-template-columns: 1fr; }
    }
  </style>

  <div class="cta-hero">
    <div class="label">Work Together</div>
    <h1>Working together.</h1>
    <p>I take on a small number of engagements each quarter. If you think there's a fit, reach out.</p>
  </div>

  <section>
    <div class="offerings">
      {offerings.map((o) => (
        <div class="offering-card">
          <div class="offering-label">{o.label}</div>
          <h3>{o.title}</h3>
          <p>{o.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="contact">
    <a href="mailto:angwinconsulting@gmail.com" class="btn">Say Hello</a>
  </section>
</Base>
