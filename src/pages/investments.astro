---

<Base title="Investments — Angela Winegar" description="Angel portfolio of early-stage companies.">
  <style>
    .portfolio-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 2rem;
    }

    .portfolio-header h1 {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 700;
    }

    .portfolio-note {
      font-size: 0.78rem;
      color: var(--color-muted);
      align-self: flex-end;
      padding-bottom: 0.25rem;
    }

    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.875rem;
    }

    .portfolio-card {
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-top: 3px solid var(--card-color, var(--color-border));
      border-radius: var(--radius);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: var(--color-text);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .portfolio-card:hover {
      transform: translateY(-2px);
      box-shadow: none;
      background: color-mix(in srgb, var(--card-color) 7%, var(--color-bg));
    }

    .portfolio-card.is-exit:hover {
      background: color-mix(in srgb, var(--card-color) 12%, var(--color-surface-dark));
    }

    .portfolio-card:not(.is-exit):hover .company-name {
      color: var(--card-color);
    }

    .portfolio-card.is-exit {
      background: var(--color-surface-dark);
      border-color: transparent;
      border-top-color: var(--card-color, #4A6868);
      color: #F7F3EE;
    }

    .portfolio-card.is-exit .company-space,
    .portfolio-card.is-exit .company-desc {
      color: #9A9289;
    }

    .portfolio-card.is-exit .acq-badge {
      background: rgba(255,255,255,0.08);
      border-color: rgba(255,255,255,0.15);
      color: #C8BFB4;
    }

    .card-logo-wrap {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
    }

    .card-logo {
      width: 38px;
      height: 38px;
      border-radius: 5px;
      object-fit: cover;
      image-rendering: -webkit-optimize-contrast;
    }

    .text-logo {
      width: 38px;
      height: 38px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-display);
      font-size: 1rem;
      font-weight: 700;
      color: var(--color-text);
      background: var(--color-surface);
      border-radius: 5px;
      letter-spacing: -0.02em;
    }

    .acq-badge {
      font-size: 0.62rem;
      font-weight: 600;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      color: var(--color-teal);
      padding: 0.18rem 0.55rem;
      border-radius: 3px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .company-space {
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-muted);
      margin-bottom: 0.4rem;
    }

    .company-name {
      font-family: var(--font-display);
      font-size: 1.05rem;
      font-weight: 700;
      margin-bottom: 0.65rem;
    }

    .company-desc {
      font-size: 0.825rem;
      color: var(--color-muted);
      line-height: 1.6;
      flex: 1;
    }

    .exits-divider {
      margin-top: 3rem;
      margin-bottom: 1.5rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--color-border);
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-muted);
    }

    @media (max-width: 860px) {
      .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 580px) {
      .portfolio-grid { grid-template-columns: 1fr; }
    }
  </style>

  <div class="label">Angel Investing</div>
  <div class="portfolio-header">
    <h1>Portfolio</h1>
    <span class="portfolio-note"><em>select non-stealth investments</em></span>
  </div>

  <div class="portfolio-grid">
    {active.map((co) => (
      <a
        href={co.link}
        target="_blank"
        class={`portfolio-card${co.exit ? ' is-exit' : ''}`}
        style={`--card-color: ${co.color}`}
      >
        <div class="card-logo-wrap">
          {co.textLogo
            ? <div class="text-logo">{co.textLogo}</div>
            : <img class="card-logo" src={co.logo} alt={co.name} onerror="this.style.display='none'" />
          }
          {co.acq && <span class="acq-badge">{co.acq}</span>}
        </div>
        <div class="company-space">{co.space}</div>
        <div class="company-name">{co.name}</div>
        <p class="company-desc">{co.description}</p>
      </a>
    ))}
  </div>

  <div class="exits-divider">Exits</div>

  <div class="portfolio-grid">
    {exits.map((co) => (
      <a
        href={co.link}
        target="_blank"
        class={`portfolio-card${co.exit ? ' is-exit' : ''}`}
        style={`--card-color: ${co.color}`}
      >
        <div class="card-logo-wrap">
          {co.textLogo
            ? <div class="text-logo">{co.textLogo}</div>
            : <img class="card-logo" src={co.logo} alt={co.name} onerror="this.style.display='none'" />
          }
          {co.acq && <span class="acq-badge">{co.acq}</span>}
        </div>
        <div class="company-space">{co.space}</div>
        <div class="company-name">{co.name}</div>
        <p class="company-desc">{co.description}</p>
      </a>
    ))}
  </div>
</Base>
