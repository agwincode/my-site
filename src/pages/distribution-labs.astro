---
// Standalone page for Distribution Labs within angelawinegar.com
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Distribution Labs - High-Stakes GTM Strategy for Venture-Backed Teams" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
		<title>Distribution Labs | High-Stakes GTM</title>
	</head>
	<body class="distro-body">
		<div class="grain"></div>
		
		<main>
			<!-- HERO SECTION -->
			<section class="hero-final reveal">
				<div class="glow-wrap">
					<div class="glow-periwinkle"></div>
				</div>
				<div class="container">
					<nav class="nav-minimal">
						<span class="logo">DISTRIBUTION LABS</span>
						<div class="nav-links-minimal">
							<a href="#offerings">Offerings</a>
							<a href="#about">About</a>
							<button class="btn-cta-small">Book Session</button>
						</div>
					</nav>

					<div class="hero-center">
						<p class="tagline-lab" data-value="DISTRIBUTION LABS // GTM_STRATEGY">DISTRIBUTION LABS // GTM_STRATEGY</p>
						<h1 class="serif-h1-main">GTM for the high-leverage era. <span>AI-native growth ops.</span></h1>
						<p class="subhead-final">
							We are your GTM sparring partners. We help venture-backed teams build the engines that bridge the gap from product-market fit to enterprise-scale distribution.
						</p>
						<div class="v-links-final">
							<a href="#offerings" class="btn-breathing">View Sprints</a>
							<span class="v-divider">/</span>
							<a href="#contact">Book Session</a>
						</div>
					</div>
				</div>
			</section>

			<!-- LOGO STRIP -->
			<section class="logo-strip reveal">
				<div class="container">
					<p class="strip-label">FROM 8-FIGURE FOUNDATIONS TO 9-FIGURE MARKET LEADERS</p>
					<div class="logo-grid floating-logos">
						<!-- Asana -->
						<img src="https://www.vectorlogo.zone/logos/asana/asana-ar21.svg" alt="Asana" class="logo-img" />
						<!-- Carta -->
						<img src="https://upload.wikimedia.org/wikipedia/commons/8/8a/Carta-logo.svg" alt="Carta" class="logo-img" />
						<!-- Dropbox -->
						<img src="https://www.vectorlogo.zone/logos/dropbox/dropbox-ar21.svg" alt="Dropbox" class="logo-img logo-dropbox" />
						<!-- Invisible Technologies -->
						<img src="https://cdn.prod.website-files.com/684704669d08b247ce01fc71/696aa54f553448ee6807fc3f_9b550bd9d3ed8ecb05d19aca8fe5eca1_PrimaryLogoLight.png" alt="Invisible Technologies" class="logo-img logo-invisible" />
					</div>
					<p class="strip-subtext">We've repeatedly built the growth engines that define categories. Now, we're building yours.</p>
				</div>
			</section>

			<!-- AI PHILOSOPHY -->
			<section class="philosophy-section reveal">
				<div class="container">
					<div class="philosophy-card">
						<div class="philosophy-content">
							<span class="badge">OUR STANCE</span>
							<h2>AI-Enabled, <span>Not AI-Slop.</span></h2>
							<p>
								We are not cavemen who ignore AI, but we are also not peddlers of unedited, low-signal automation. We believe that <strong>deep, rigorous research</strong> is what defines a good marketing and growth foundation. We use AI to remove the friction of execution, while doubling down on the human intelligence required for high-trust strategy.
							</p>
						</div>
					</div>
				</div>
			</section>

			<!-- SERIES-A TICKER -->
			<div class="ticker-wrap reveal">
				<div class="ticker">
					<span>ROBOTICS // ARTIFICIAL INTELLIGENCE // PUBLIC SAFETY // DEEP TECH // DEFENSE // ROBOTICS // ARTIFICIAL INTELLIGENCE // PUBLIC SAFETY // DEEP TECH // DEFENSE</span>
				</div>
			</div>

			<!-- BENTO OFFERINGS -->
			<section id="offerings" class="bento-section">
				<div class="container">
					<h2 class="section-title reveal">Productized Sprints</h2>
					
					<div class="bento-grid">
						<!-- 1. POSITIONING -->
						<div class="bento-card flagship anodized sheen">
							<div class="card-content">
								<span class="badge">CATEGORY LEADERSHIP</span>
								<h3>Strategic Positioning & Narrative</h3>
								<p>In a world of rapid commoditization, differentiation is a moving target. We identify the specific wedge that wins category authority and translate it into a high-trust narrative that breaks through the noise.</p>
							</div>
						</div>

						<!-- 2. PLG -->
						<div class="bento-card anodized sheen">
							<div class="card-content">
								<span class="badge">REVENUE ACCELERATION</span>
								<h3>PLG & Monetization Engine</h3>
								<p>Bridge the gap between bottom-up user growth and top-down enterprise procurement.</p>
							</div>
						</div>

						<!-- 3. FRACTIONAL CMO -->
						<div class="bento-card anodized sheen">
							<div class="card-content">
								<span class="badge">OPERATIONAL SCALE</span>
								<h3>Fractional CMO for AI-Native Orgs</h3>
								<p>Embed an operator-led growth function into your team. We manage the transition from experiment to high-leverage marketing engine.</p>
							</div>
						</div>

						<!-- 4. COMMS & AUTHORITY -->
						<div class="bento-card advisory anodized sheen">
							<div class="card-content">
								<span class="badge">MARKET AUTHORITY</span>
								<h3>Comms Strategy & Executive Authority</h3>
								<p>Architect the founding story and executive roadmap. High-signal direction that wins category mindshare, without the execution burden.</p>
							</div>
						</div>

						<!-- 5. ORG DESIGN -->
						<div class="bento-card anodized sheen">
							<div class="card-content">
								<span class="badge">FUTURE OF WORK</span>
								<h3>AI-Native Org Design</h3>
								<p>In a world of shifting boundaries, we define where the human ends and the agent begins. Build a lean, hybrid team optimized for the high-leverage era.</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="about" class="about-section reveal">
				<div class="container">
					<div class="about-grid">
						<div class="about-text">
							<h2>Your Sparring Partners</h2>
							<p>We aren't career consultants. We are operators who have owned P&Ls, built AI marketing teams from scratch, and analyzed thousands of startups from the VC side.</p>
						</div>
						<div class="about-stats">
							<div class="stat-item"><span>$XM</span><p>Revenue Managed</p></div>
							<div class="stat-item"><span>100+</span><p>Startups Advised</p></div>
						</div>
					</div>
				</div>
			</section>

			<footer class="reveal">
				<div class="container">
					<div class="footer-wrap">
						<span class="logo">DISTRIBUTION LABS</span>
						<p>&copy; {new Date().getFullYear()} Distribution Labs. All rights reserved.</p>
					</div>
				</div>
			</footer>
		</main>

		<script>
			// 1. Scroll Tracking for Parallax Grid
			window.addEventListener('scroll', () => {
				document.body.style.setProperty('--scroll', window.pageYOffset.toString());
			});

			// 2. Intersection Observer for Reveal Animations
			const observerOptions = {
				threshold: 0.1,
				rootMargin: '0px 0px -50px 0px'
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('active');
						if (entry.target.classList.contains('bento-grid')) {
							const cards = entry.target.querySelectorAll('.bento-card');
							cards.forEach((card, index) => {
								setTimeout(() => card.classList.add('active'), index * 150);
							});
						}
					}
				});
			}, observerOptions);

			document.querySelectorAll('.reveal, .bento-grid').forEach(el => observer.observe(el));

			// 3. Tagline Decipher Animation
			const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789//_";
			document.querySelectorAll('.tagline-lab').forEach(tag => {
				let interval = null;
				tag.onmouseover = event => {  
					let iteration = 0;
					clearInterval(interval);
					interval = setInterval(() => {
						event.target.innerText = event.target.innerText
							.split("")
							.map((letter, index) => {
								if(index < iteration) return event.target.dataset.value[index];
								return letters[Math.floor(Math.random() * 39)]
							})
							.join("");
						if(iteration >= event.target.dataset.value.length) clearInterval(interval);
						iteration += 1 / 3;
					}, 30);
				};
			});
		</script>
	</body>
</html>

<style is:global>
	:root {
		--bg-charcoal: #12100E; /* Warm Black */
		--fg-white: #F5F5F0;    /* Off White */
		--fg-muted: #94918C;    /* Muted Gray */
		--p-orange: #E66B3D;
		--p-pink: #E6B3C7;
		--p-gray: #94918C;
		--p-brown: #633324;
		--p-blue: #4D61FF;
		--p-sky: #B4B8F0;
		--p-olive: #8A8E3D;
		--p-green: #2D4D35;
		--border-dim: rgba(245, 245, 240, 0.1);
		--font-serif: 'Optima', 'Candara', 'Segoe UI', source-sans-pro, sans-serif;
		--font-sans: 'Helvetica Now Condensed', 'Helvetica Neue Condensed', 'Arial Narrow', sans-serif;
		--scroll: 0;
	}

	.distro-body {
		background: var(--bg-charcoal) !important;
		color: var(--fg-white) !important;
		font-family: var(--font-sans) !important;
		margin: 0;
		padding: 0;
		overflow-x: hidden;
		-webkit-font-smoothing: antialiased;
	}

	.distro-body * { box-sizing: border-box; }

	/* Grain Texture */
	.grain {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 99;
		opacity: 0.04;
		background-image: url('https://grainy-gradients.vercel.app/noise.svg');
	}

	/* Grid Pattern with Parallax */
	.distro-body::before {
		content: "";
		position: fixed;
		top: -50%;
		left: -50%;
		width: 200%;
		height: 200%;
		background-image: 
			linear-gradient(to right, var(--border-dim) 1px, transparent 1px),
			linear-gradient(to bottom, var(--border-dim) 1px, transparent 1px);
		background-size: 60px 60px;
		z-index: -1;
		pointer-events: none;
		transform: translateY(calc(var(--scroll) * -0.2px));
		opacity: 0.6;
	}

	/* Fade out grid at bottom */
	.distro-body::after {
		content: "";
		position: fixed;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 40vh;
		background: linear-gradient(to top, var(--bg-charcoal), transparent);
		z-index: -1;
		pointer-events: none;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
		position: relative;
	}

	h1, h2, h3 { font-family: var(--font-serif); font-weight: 400; }

	/* Animations */
	.reveal {
		opacity: 0;
		transform: translateY(30px);
		transition: all 0.8s cubic-bezier(0.23, 1, 0.32, 1);
	}
	.reveal.active {
		opacity: 1 !important;
		transform: translateY(0) !important;
	}

	/* Final Hero Styling */
	.hero-final {
		min-height: 90vh;
		display: flex;
		flex-direction: column;
		position: relative;
		overflow: hidden;
		padding-bottom: 4rem;
	}
	.glow-wrap {
		position: absolute;
		top: -20%;
		left: 50%;
		transform: translateX(-50%);
		width: 100%;
		height: 100%;
		z-index: -1;
		pointer-events: none;
	}
	.glow-periwinkle {
		width: 60vw;
		height: 60vw;
		background: radial-gradient(circle, var(--p-sky) 0%, transparent 70%);
		opacity: 0.08;
		filter: blur(100px);
	}

	.nav-minimal {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 2.5rem 0;
	}
	.logo {
		font-family: var(--font-sans);
		font-weight: 600;
		letter-spacing: 0.2rem;
		font-size: 0.9rem;
		color: var(--fg-white);
	}
	.nav-links-minimal {
		display: flex;
		align-items: center;
		gap: 3rem;
	}
	.nav-links-minimal a {
		color: var(--fg-muted);
		text-decoration: none;
		font-size: 0.8rem;
		letter-spacing: 0.1rem;
		text-transform: uppercase;
		transition: all 0.3s;
		position: relative;
		padding-bottom: 4px;
	}
	.nav-links-minimal a::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 1px;
		background: var(--p-orange);
		transition: width 0.3s;
	}
	.nav-links-minimal a:hover { color: var(--fg-white); }
	.nav-links-minimal a:hover::after { width: 100%; }

	.btn-cta-small {
		background: transparent;
		color: var(--fg-white);
		border: 1px solid var(--border-dim);
		padding: 0.5rem 1rem;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1rem;
		cursor: pointer;
		transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
	}
	.btn-cta-small:hover { 
		border-color: var(--p-sky); 
		transform: translateY(-2px);
		box-shadow: 0 0 20px rgba(180, 184, 240, 0.2);
		background: rgba(180, 184, 240, 0.05);
	}

	.hero-center {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		max-width: 900px;
		margin: 0 auto;
		padding-top: 4rem;
	}
	.tagline-lab {
		font-size: 0.65rem;
		letter-spacing: 0.4rem;
		color: var(--p-orange);
		margin-bottom: 2.5rem;
		font-weight: 600;
		cursor: default;
	}
	.serif-h1-main {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: 5rem;
		line-height: 1.1;
		margin-bottom: 2.5rem;
		letter-spacing: -0.02rem;
	}
	.serif-h1-main span {
		display: block;
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 3.5rem;
		color: var(--p-sky);
		letter-spacing: -0.05rem;
		margin-top: 0.5rem;
	}
	.subhead-final {
		font-family: var(--font-serif);
		font-size: 1.4rem;
		color: var(--fg-muted);
		line-height: 1.6;
		max-width: 700px;
		margin-bottom: 3.5rem;
		font-style: italic;
	}
	.v-links-final {
		display: flex;
		gap: 2rem;
		align-items: center;
	}
	.v-links-final a {
		color: var(--fg-white);
		text-decoration: none;
		font-size: 1.1rem;
		border-bottom: 1px solid rgba(180, 184, 240, 0.3);
		padding-bottom: 0.2rem;
		transition: all 0.3s;
		display: inline-block;
	}
	.v-links-final a:hover { 
		border-color: var(--p-sky); 
		color: var(--p-sky);
		transform: translateX(5px);
	}
	.v-divider { color: var(--border-dim); font-size: 1.2rem; }

	/* Logo Strip */
	.logo-strip {
		padding: 6rem 0;
		background: rgba(255, 255, 255, 0.02);
		border-top: 1px solid var(--border-dim);
		border-bottom: 1px solid var(--border-dim);
	}
	.strip-label {
		font-size: 0.75rem;
		letter-spacing: 0.2rem;
		color: var(--p-orange);
		text-align: center;
		margin-bottom: 2.5rem;
		font-weight: 600;
	}
	.logo-grid {
		display: flex;
		justify-content: center;
		align-items: center;
		opacity: 0.9;
		gap: 4rem;
		margin-bottom: 2.5rem;
		flex-wrap: wrap;
	}
	.logo-img {
		height: 48px;
		width: auto;
		max-width: 200px;
		filter: brightness(0) invert(1);
		transition: transform 0.3s;
	}
	.logo-img:hover { transform: scale(1.05); }
	.logo-dropbox { height: 60px; max-width: 240px; }
	.logo-invisible { height: 85px; max-width: 320px; margin-left: -1.5rem; }
	.strip-subtext {
		text-align: center;
		font-family: var(--font-serif);
		font-size: 1.1rem;
		color: var(--fg-muted);
		font-style: italic;
		max-width: 600px;
		margin: 0 auto;
	}

	/* Floating Logos */
	@keyframes float {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-20px); }
	}
	.floating-logos .logo-img { animation: float 6s ease-in-out infinite; }
	.floating-logos .logo-img:nth-child(2) { animation-delay: 1s; }
	.floating-logos .logo-img:nth-child(3) { animation-delay: 2s; }
	.floating-logos .logo-img:nth-child(4) { animation-delay: 3s; }

	/* Philosophy Section */
	.philosophy-section { padding: 8rem 0 4rem; }
	.philosophy-card {
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, rgba(10, 10, 10, 1) 100%);
		border: 1px solid var(--border-dim);
		padding: 4rem;
		max-width: 900px;
		margin: 0 auto;
		position: relative;
		overflow: hidden;
	}
	.philosophy-card h2 { font-size: 3rem; margin-bottom: 1.5rem; }
	.philosophy-card h2 span { color: var(--p-orange); font-style: italic; }
	.philosophy-card p { font-size: 1.25rem; line-height: 1.7; color: var(--fg-muted); }
	.philosophy-card p strong { color: var(--fg-white); }

	/* Ticker */
	.ticker-wrap {
		width: 100%;
		overflow: hidden;
		background: rgba(138, 142, 61, 0.03);
		border-top: 1px solid rgba(138, 142, 61, 0.1);
		border-bottom: 1px solid rgba(138, 142, 61, 0.1);
		padding: 1rem 0;
		margin: 2rem 0;
	}
	.ticker {
		white-space: nowrap;
		animation: ticker 35s linear infinite;
		font-size: 0.85rem;
		letter-spacing: 0.5rem;
		font-weight: 700;
		color: var(--p-olive);
		text-shadow: 0 0 10px rgba(138, 142, 61, 0.2);
	}
	@keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

	/* Bento Grid */
	.bento-section { padding: 8rem 0; position: relative; }
	.section-title { font-size: 2.5rem; margin-bottom: 4rem; }
	.bento-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		grid-auto-rows: 280px;
		gap: 1.5rem;
		z-index: 2;
		position: relative;
	}
	.bento-card {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--border-dim);
		padding: 2rem;
		position: relative;
		overflow: hidden;
		transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
		opacity: 0;
		transform: translateY(20px);
	}
	.bento-card.active { opacity: 1 !important; transform: translateY(0) !important; }
	.flagship {
		grid-column: span 2;
		background: linear-gradient(135deg, rgba(45, 77, 53, 0.2) 0%, rgba(10, 10, 10, 1) 100%);
	}
	.anodized:hover {
		border-color: var(--p-blue);
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(10, 10, 10, 1) 100%);
		transform: translateY(-5px);
	}

	/* Sheen Animation */
	@keyframes sheen {
		0% { transform: translateX(-100%) rotate(45deg); }
		100% { transform: translateX(200%) rotate(45deg); }
	}
	.sheen::after {
		content: "";
		position: absolute;
		top: -50%; left: -50%; width: 200%; height: 200%;
		background: linear-gradient(to right, transparent, rgba(255,255,255,0.05), transparent);
		transform: rotate(45deg);
		animation: sheen 10s infinite;
		pointer-events: none;
	}

	/* Button Breathing */
	@keyframes breathe {
		0%, 100% { box-shadow: 0 0 10px rgba(180, 184, 240, 0.1); }
		50% { box-shadow: 0 0 25px rgba(180, 184, 240, 0.3); }
	}
	.btn-breathing { animation: breathe 4s ease-in-out infinite; }

	.badge {
		font-size: 0.65rem;
		letter-spacing: 0.1rem;
		color: var(--p-orange);
		border: 1px solid rgba(230, 107, 61, 0.3);
		padding: 0.3rem 0.6rem;
		display: inline-block;
		margin-bottom: 1.5rem;
	}
	.bento-card h3 { font-size: 1.5rem; margin-bottom: 1rem; }
	.bento-card p { color: var(--fg-muted); font-size: 0.95rem; line-height: 1.5; }

	/* About Section */
	.about-section { padding: 8rem 0; background: rgba(255, 255, 255, 0.02); }
	.about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
	.about-text h2 { font-size: 3rem; margin-bottom: 2rem; }
	.about-text p { font-size: 1.2rem; color: var(--fg-muted); line-height: 1.6; }
	.about-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
	.stat-item span { font-family: var(--font-serif); font-size: 3rem; color: var(--p-sky); display: block; }
	.stat-item p { color: var(--fg-muted); font-size: 0.9rem; }

	/* Footer */
	footer { padding: 4rem 0; border-top: 1px solid var(--border-dim); }
