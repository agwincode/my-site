---

<section class="hero-final reveal">
	<div class="glow-wrap">
		<div class="glow-periwinkle"></div>
	</div>

	<!-- Background Video (Pinned Right) -->
	<div class="hero-video-bg">
		<video autoplay muted loop playsinline class="hero-video">
			<source src="/bg-video.mp4?v=2" type="video/mp4">
		</video>
		<div class="hero-video-fade"></div>
	</div>

	<div class="container hero-container">
		<nav class="nav-minimal">
			<span class="logo">DISTRIBUTION LABS</span>
			<div class="nav-links-minimal">
				<a href="#offerings">Offerings</a>
				<a href="#about">About</a>
				<button class="btn-cta-small">Book Session</button>
			</div>
		</nav>

		<div class="hero-split">
			<div class="hero-content">
				<p class="tagline-lab" data-value="DISTRIBUTION LABS // GTM_STRATEGY">DISTRIBUTION LABS // GTM_STRATEGY</p>
				<h1 class="serif-h1-main">The future belongs to storytellers. <span>Your growth insurance policy.</span></h1>
				<p class="subhead-final">
					We are your GTM sparring partners. We help venture-backed teams build the engines that bridge the gap from product-market fit to enterprise-scale distribution.
				</p>
				<div class="v-links-final">
					<a href="#offerings" class="btn-breathing">View Sprints</a>
					<span class="v-divider">/</span>
					<a href="#contact">Book Session</a>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	// Tagline Decipher Animation
	const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789//_";
	document.querySelectorAll('.tagline-lab').forEach(tag => {
		let interval = null;
		tag.onmouseover = event => {  
			let iteration = 0;
			clearInterval(interval);
			interval = setInterval(() => {
				const target = event.target as HTMLElement;
				target.innerText = target.innerText
					.split("")
					.map((letter, index) => {
						if(index < iteration) return target.dataset.value![index];
						return letters[Math.floor(Math.random() * 39)]
					})
					.join("");
				if(iteration >= target.dataset.value!.length) clearInterval(interval);
				iteration += 1 / 3;
			}, 30);
		};
	});
</script>

<style>
	/* Final Hero Styling */
	.hero-final {
		min-height: 95vh;
		display: flex;
		flex-direction: column;
		position: relative;
		overflow: hidden;
		padding-bottom: 4rem;
	}

	.hero-container {
		max-width: 1400px !important;
		margin-left: 0 !important;
		padding-left: 4rem !important;
	}

	/* Video Background (Right Aligned) */
	.hero-video-bg {
		position: absolute;
		top: 0;
		right: 0;
		width: 70vw; /* Spans 70% of the width from the right */
		height: 100%;
		z-index: -2; /* Behind the grid (z-index: -1) */
		pointer-events: none;
	}

	.hero-video {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.55;
		filter: grayscale(40%) contrast(1.1);
	}

	/* Mask to fade video into the dark background on the left */
	.hero-video-fade {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(to right, 
			var(--bg-charcoal) 0%, 
			rgba(18, 16, 14, 0.8) 20%, 
			transparent 50%, 
			transparent 80%, 
			var(--bg-charcoal) 100%);
	}

	.glow-wrap {
		position: absolute;
		top: -20%;
		left: 20%;
		transform: translateX(-50%);
		width: 100%;
		height: 100%;
		z-index: -1;
		pointer-events: none;
	}
	.glow-periwinkle {
		width: 60vw;
		height: 60vw;
		background: radial-gradient(circle, var(--p-sky) 0%, transparent 70%);
		opacity: 0.08;
		filter: blur(100px);
	}

	.nav-minimal {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 2.5rem 0;
		position: relative;
		z-index: 10;
	}
	.logo {
		font-family: var(--font-sans);
		font-weight: 600;
		letter-spacing: 0.2rem;
		font-size: 0.9rem;
		color: var(--fg-white);
	}
	.nav-links-minimal {
		display: flex;
		align-items: center;
		gap: 3rem;
	}
	.nav-links-minimal a {
		color: var(--fg-muted);
		text-decoration: none;
		font-size: 0.8rem;
		letter-spacing: 0.1rem;
		text-transform: uppercase;
		transition: all 0.3s;
		position: relative;
		padding-bottom: 4px;
	}
	.nav-links-minimal a::after {
		content: "";
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 1px;
		background: var(--p-orange);
		transition: width 0.3s;
	}
	.nav-links-minimal a:hover { color: var(--fg-white); }
	.nav-links-minimal a:hover::after { width: 100%; }

	.btn-cta-small {
		background: transparent;
		color: var(--fg-white);
		border: 1px solid var(--border-dim);
		padding: 0.5rem 1rem;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1rem;
		cursor: pointer;
		transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
	}
	.btn-cta-small:hover { 
		border-color: var(--p-sky); 
		transform: translateY(-2px);
		box-shadow: 0 0 20px rgba(180, 184, 240, 0.2);
		background: rgba(180, 184, 240, 0.05);
	}

	/* Split Content Alignment */
	.hero-split {
		display: flex;
		align-items: center;
		flex: 1;
		padding-top: 4rem;
	}

	.hero-content {
		text-align: left;
		position: relative;
		z-index: 5;
		max-width: 800px;
	}

	.tagline-lab {
		font-size: 0.65rem;
		letter-spacing: 0.4rem;
		color: var(--p-orange);
		margin-bottom: 1.5rem;
		font-weight: 600;
		cursor: default;
	}
	.serif-h1-main {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: 4.5rem;
		line-height: 1.05;
		margin-bottom: 2.5rem;
		letter-spacing: -0.02rem;
		max-width: 700px;
	}
	.serif-h1-main span {
		display: block;
		font-family: var(--font-sans);
		font-weight: 700;
		font-size: 3rem;
		color: var(--p-sky);
		letter-spacing: -0.05rem;
		margin-top: 0.5rem;
	}
	.subhead-final {
		font-family: var(--font-serif);
		font-size: 1.3rem;
		color: var(--fg-muted);
		line-height: 1.6;
		max-width: 540px;
		margin-bottom: 3.5rem;
		font-style: italic;
	}
	.v-links-final {
		display: flex;
		gap: 2rem;
		align-items: center;
	}
	.v-links-final a {
		color: var(--fg-white);
		text-decoration: none;
		font-size: 1.1rem;
		border-bottom: 1px solid rgba(180, 184, 240, 0.3);
		padding-bottom: 0.2rem;
		transition: all 0.3s;
		display: inline-block;
	}
	.v-links-final a:hover { 
		border-color: var(--p-sky); 
		color: var(--p-sky);
		transform: translateX(5px);
	}
	.v-divider { color: var(--border-dim); font-size: 1.2rem; }

	/* Button Breathing */
	@keyframes breathe {
		0%, 100% { box-shadow: 0 0 10px rgba(180, 184, 240, 0.1); }
		50% { box-shadow: 0 0 25px rgba(180, 184, 240, 0.3); }
	}
	.btn-breathing { animation: breathe 4s ease-in-out infinite; }

	@media (max-width: 1100px) {
		.serif-h1-main { font-size: 3.5rem; }
		.serif-h1-main span { font-size: 2.5rem; }
		.hero-video-bg { width: 80vw; }
		.hero-container { padding-left: 2rem !important; }
	}

	@media (max-width: 968px) {
		.hero-final { min-height: 80vh; }
		.hero-content { text-align: center; margin: 0 auto; }
		.subhead-final { margin: 0 auto 3.5rem; }
		.v-links-final { justify-content: center; }
		.hero-video-bg { width: 100vw; opacity: 0.3; }
		.serif-h1-main { margin: 0 auto 2.5rem; }
		.hero-container { padding-left: 1.5rem !important; }
	}

	@media (max-width: 768px) {
		.hero-final { padding-bottom: 2rem; }
		.nav-minimal { flex-direction: column; gap: 1.5rem; padding: 2rem 0; }
		.nav-links-minimal { gap: 1.25rem; }
		
		.serif-h1-main { font-size: 2.75rem; }
		.serif-h1-main span { font-size: 2rem; }
		
		.v-links-final { flex-direction: column; gap: 1.25rem; }
		.v-divider { display: none; }
		.v-links-final a { width: 100%; text-align: center; }
	}
</style>