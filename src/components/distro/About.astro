---

<section id="about" class="about-section reveal">
	<div class="container">
		<div class="about-split">
			<div class="about-left">
				<h2>Built by Operators, Not Analysts.</h2>
				<p class="about-lead">We aren't career consultants. We are operators who have owned P&Ls, built AI marketing teams from scratch, and analyzed thousands of startups from the VC side.</p>
			</div>
			
			<div class="model-stack">
				<div class="pill-stack">
					<div class="pill-item"><span class="dot"></span> Weekly Velocity</div>
					<div class="pill-item"><span class="dot"></span> 4-Week Sprints</div>
					<div class="pill-item"><span class="dot"></span> AI-Native Systems</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.about-section { padding: 6rem 0; background: rgba(255, 255, 255, 0.01); border-top: 1px solid var(--border-dim); }
	.about-split {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		gap: 6rem;
		align-items: start;
	}
	.about-left h2 { font-size: 3.5rem; line-height: 1.1; margin-bottom: 2rem; }
	.about-lead { font-family: var(--font-serif); font-size: 1.4rem; color: var(--fg-muted); font-style: italic; line-height: 1.5; }
	
	.model-stack {
		display: flex;
		flex-direction: column;
		margin-top: 4.5rem;
	}
	.pill-stack { display: flex; flex-direction: column; gap: 1rem; }
	.pill-item {
		background: rgba(255, 255, 255, 0.03);
		padding: 1rem 2rem;
		border-radius: 100px;
		font-size: 1rem;
		display: flex;
		align-items: center;
		gap: 1.5rem;
		border: 1px solid var(--border-dim);
		width: fit-content;
		font-family: var(--font-sans);
		color: var(--fg-white);
		transition: all 0.3s ease;
	}
	.pill-item:hover {
		background: rgba(255, 255, 255, 0.05);
		border-color: var(--p-orange);
		transform: translateX(5px);
	}
	.pill-item .dot { width: 10px; height: 10px; background: var(--p-orange); border-radius: 50%; box-shadow: 0 0 15px var(--p-orange); }

	@media (max-width: 968px) {
		.about-split { grid-template-columns: 1fr; gap: 4rem; }
		.about-left h2 { font-size: 2.5rem; }
	}

	@media (max-width: 768px) {
		.about-section { padding: 4rem 0; }
		.about-left h2 { font-size: 2.25rem; text-align: center; }
		.about-lead { font-size: 1.15rem; text-align: center; line-height: 1.6; }
		
		.model-stack { margin-top: 3rem; }
		.pill-stack { align-items: center; }
		.pill-item { padding: 0.8rem 1.5rem; font-size: 0.9rem; width: 100%; justify-content: flex-start; }
	}
</style>
